# One worktree = one private dev stack, declared here. Copy this file to `.env` at the
# repo root (it is gitignored) and change every port to values nothing else on your
# machine uses. Declaring a stack costs disk, not memory - nothing starts until you
# start it. Full walkthrough: docs/molgenis/dev_quickstart.md, "Parallel dev stacks".
#
# Who reads this file:
#   - Gradle AUTO-READS it (straight from disk at configuration time, so it is
#     daemon-safe) and applies EVERY key as a system property to the forked
#     test/run/dev/cleandb JVMs - postgres settings, feature flags, anything the code
#     reads via EnvironmentProperty. No `source` needed.
#   - the frontend dev servers read it via apps/dev-env.js (the Nuxt `dev` scripts pass
#     `--dotenv=../../.env`).
#   - IntelliJ does NOT. Gradle's forwarding only reaches JVMs Gradle forks, so an IDE
#     run configuration needs these set by hand as env vars or -D VM options, or it
#     silently targets the DEFAULT database on :5432 and port :8080.
#
# Precedence per key: shell environment > this file > code default. So NEVER export
# these from ~/.zshrc - a machine-global export overrides the .env of every worktree at
# once and pins every dev server to the wrong backend.
#
# Run ./dev-preflight before starting a stack: it cross-checks Gradle's resolved config
# against the apps' resolved config and exits non-zero with a remedy.

# --- database -----------------------------------------------------------------------
# A separate Postgres INSTANCE per worktree, not just a separate database name: roles
# are cluster-wide and `cleandb` drops every MG_%/test%/user_% role in the cluster.
# Stand one up (example: Postgres.app), then seed the molgenis db/user:
#   psql -p 5435 -f .circleci/initdb.sql
MOLGENIS_POSTGRES_URI=jdbc:postgresql://localhost:5435/molgenis
MOLGENIS_POSTGRES_USER=molgenis
MOLGENIS_POSTGRES_PASS=molgenis

# --- backend ------------------------------------------------------------------------
# HTTP port that `./gradlew dev` and `./gradlew run` bind (default 8080). Stay off 8080
# (somebody else's checkout has it) and off 8081 (historically the webapi test port).
MOLGENIS_HTTP_PORT=8083

# Heap cap for the dev/run JVM. Unset means unbounded - the measured JVM default here is
# a 6144 MB max heap. 1g is comfortable: the backend measures ~340 MB RSS while serving
# GraphQL. Not applied to test tasks.
MOLGENIS_JVM_XMX=1g

# --- what the frontends talk to -----------------------------------------------------
# The backend the ~20 Vite apps sharing apps/dev-proxy.config.js talk to, plus `central`
# and `directory`, which keep their own route maps. Must match MOLGENIS_HTTP_PORT.
MOLGENIS_APPS_HOST=http://localhost:8083

# The backend the Nuxt apps (tailwind-components, ui, catalogue) talk to. Dev only: the
# Nitro server routes that use it do not exist in a static `nuxt generate` build.
NUXT_PUBLIC_API_BASE=http://localhost:8083/

# Schema filled in for the SCHEMA-LESS dev-proxy routes of the shared-proxy Vite apps:
# /graphql -> ${MOLGENIS_APPS_HOST}/${MOLGENIS_APPS_SCHEMA}/graphql, likewise /reports
# and /theme.css. Routes that already carry a schema in the path are unaffected. Set it
# if you develop against anything other than the default `pet store` (`directory`
# defaults to `directory-demo`).
#MOLGENIS_APPS_SCHEMA=pet store

# --- app dev-server ports -----------------------------------------------------------
# One port per app, bound STRICTLY: a busy declared port errors out instead of silently
# drifting onto the next app's port. Playwright resolves each suite's baseURL from the
# same key, so e2e hits the app you started. Unset means today's default (Nuxt 3000,
# Vite 5173) with drift.
MOLGENIS_PORT_APP_CATALOGUE=3030
MOLGENIS_PORT_APP_TAILWIND=3031
MOLGENIS_PORT_APP_UI=3032
MOLGENIS_PORT_APP_CENTRAL=3033
MOLGENIS_PORT_APP_DIRECTORY=3034
