# Point the EMX2 backend at a dedicated dev Postgres (no Docker required).
#
# Stand up the DB (example: native Postgres.app):
#   - Postgres.app -> add a 2nd server on port 5433 (PostgreSQL 15)
#   - seed the molgenis db/user if absent:
#       psql -p 5433 -f .circleci/initdb.sql
#
# Recommended DAEMON-SAFE usage (a running Gradle daemon may ignore `source .env`
# env vars, so prefer -D system properties which are forwarded to the forked JVM):
#   ./gradlew :backend:<module>:test -DMOLGENIS_POSTGRES_URI=jdbc:postgresql://localhost:5433/molgenis
#   ./gradlew :backend:molgenis-emx2-webapi:dev -DMOLGENIS_POSTGRES_URI=jdbc:postgresql://localhost:5433/molgenis
#   ./gradlew :backend:molgenis-emx2-sql:cleandb -DMOLGENIS_POSTGRES_URI=jdbc:postgresql://localhost:5433/molgenis

POSTGRES_PORT=5433
MOLGENIS_POSTGRES_URI=jdbc:postgresql://localhost:5433/molgenis
MOLGENIS_POSTGRES_USER=molgenis
MOLGENIS_POSTGRES_PASS=molgenis
