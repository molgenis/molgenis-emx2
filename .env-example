# As developer developing at multiple branches you like to keep your work isolated (backend, postgres).
# These env variables make this possible.
#
# Copy this file to `.env` at the
# repo root (it is gitignored) and change every port to values nothing else on your
# machine uses. Full walkthrough: docs/molgenis/dev_quickstart.md, "Parallel dev stacks".
#
# FRONTEND-ONLY developer? Then delete every section marked [BACKEND-ONLY] below. If you point
# MOLGENIS_APPS_HOST / NUXT_PUBLIC_API_BASE at a backend somebody else runs, you need no
# Postgres, no MOLGENIS_HTTP_PORT and no MOLGENIS_JVM_XMX - what is left is the two host
# keys, which you UNCOMMENT below and point at that backend. MOLGENIS_HTTP_PORT is UNUSED
# when the declared host is remote.
# See dev_quickstart.md, "Frontend only".
#
# Who reads this file:
#   - Gradle AUTO-READS it (straight from disk at configuration time, so it is
#     daemon-safe) and applies EVERY key as a system property to the forked
#     test/run/dev/cleandb JVMs - postgres settings, feature flags, anything the code
#     reads via EnvironmentProperty. No `source` needed.
#   - the frontend dev servers read it via apps/dev-env.js (the Nuxt `dev` scripts pass
#     `--dotenv=../../.env`).
#   - IntelliJ does NOT. Gradle's forwarding only reaches JVMs Gradle forks, so an IDE
#     run configuration needs these set by hand as env vars or -D VM options, or it
#     silently targets the DEFAULT database on :5432 and port :8080.

# --- database [BACKEND-ONLY] ----------------------------------------------------------
# Stand new postgres up (for example using Postgres.app), then seed the molgenis db/user:
#   psql -p 5435 -f .circleci/initdb.sql
MOLGENIS_POSTGRES_URI=jdbc:postgresql://localhost:5435/molgenis
MOLGENIS_POSTGRES_USER=molgenis
MOLGENIS_POSTGRES_PASS=molgenis

# --- backend [BACKEND-ONLY] -----------------------------------------------------------
# HTTP port that `./gradlew dev` and `./gradlew run` bind (default 8080). Stay off 8080
# (somebody else's checkout has it) and off 8081 (historically the webapi test port).
MOLGENIS_HTTP_PORT=8083

# Heap cap for the dev/run JVM. This is meant to not eat up all your memory when running multiple backends.
# Not applied to test tasks.
MOLGENIS_JVM_XMX=1g

# --- what the frontends talk to [FRONTEND KEEPS THESE] --------------------------------
# Only set these to target a REMOTE backend somebody else runs. MOLGENIS_APPS_HOST is what
# all vite apps use, NUXT_PUBLIC_API_BASE what all nuxt apps use.
# Left unset, both derive from MOLGENIS_HTTP_PORT above, and that derived value OVERRIDES an
# ambient MOLGENIS_APPS_HOST / NUXT_PUBLIC_API_BASE exported in your shell.
#MOLGENIS_APPS_HOST=https://emx2.dev.molgenis.org
#NUXT_PUBLIC_API_BASE=https://emx2.dev.molgenis.org

# Schema filled in for the SCHEMA-LESS dev-proxy routes of the shared-proxy Vite apps.
# Defaults to `pet store`; `directory` defaults to `directory-demo`.
#MOLGENIS_APPS_SCHEMA=pet store
