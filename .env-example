# Local dev settings for the EMX2 backend, e.g. a dedicated dev Postgres (no Docker required).
#
# Copy this file to `.env` at the repo root. Gradle AUTO-READS `.env` (straight from
# disk at configuration time) and applies EVERY key in it as a system property to the
# forked test/run/dev/cleandb JVMs - postgres settings, feature flags, anything the code
# reads via EnvironmentProperty. No `source` needed, and it is daemon-safe.
#
# Stand up the DB (example: native Postgres.app):
#   - Postgres.app -> add a 2nd server on port 5433 (PostgreSQL 15)
#   - seed the molgenis db/user if absent:
#       psql -p 5433 -f .circleci/initdb.sql
#
# With .env in place, just run the task (no flags):
#   ./gradlew :backend:<module>:test
#   ./gradlew run
#   ./gradlew :backend:molgenis-emx2-webapi:dev
#   ./gradlew :backend:molgenis-emx2-sql:cleandb
#
# A -D system property still OVERRIDES the .env value of that key for a single run, e.g.:
#   ./gradlew run -DMOLGENIS_POSTGRES_URI=jdbc:postgresql://localhost:5433/molgenis

POSTGRES_PORT=5433
MOLGENIS_POSTGRES_URI=jdbc:postgresql://localhost:5433/molgenis
MOLGENIS_POSTGRES_USER=molgenis
MOLGENIS_POSTGRES_PASS=molgenis

# HTTP port the backend binds (default 8080). Give each checkout you run in parallel its
# own port and its own database, so they do not collide.
MOLGENIS_HTTP_PORT=8083
