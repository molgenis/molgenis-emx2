  dcat:landingPage <https://www.hongerwinter.nl/>;
  foaf:homepage <https://www.hongerwinter.nl/>;
  dcterms:description "The cohort was set up to investigate the effects of acute maternal undernutrition during specific stages of gestation on the offspringâ€™s adult health. The main outcomes of interest of the DFBC are chronic cardiovascular and metabolic diseases, ageing and mental health. Differences in various outcomes have been found between participants exposed to famine and unexposed participants. Although statistically significant, these differences are not very large, therefore adjusting for exposure group enables researchers to use DFBC data in pooled a";
  dcat:keyword "older adults", "famine", "prenatal famine exposure", "early life", "ageing",
    "Dutch", "pregnancy";
  dcat:startDate "1994"^^xsd:int;
  dcat:endDate "2021"^^xsd:int;
  healthdcatap:numberOfUniqueIndividuals "2414"^^xsd:nonNegativeInteger;
  dcterms:spatial <http://publications.europa.eu/resource/authority/country/NLD>;
  dcterms:publisher <http://localhost:8080/catalogue/api/rdf/Agents/id=Amsterdam%20UMC%20%28AMC%29&resource=DFBC>;
  dcterms:creator <http://localhost:8080/catalogue/api/rdf/Agents/id=Amsterdam%20UMC%20%28AMC%29&resource=DFBC>;
  dcat:contactPoint <http://localhost:8080/catalogue/api/rdf/Contacts/firstName=Rob&lastName=Boss&resource=DFBC>;
