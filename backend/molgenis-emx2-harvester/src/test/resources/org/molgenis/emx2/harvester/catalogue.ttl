<http://localhost:8080/catalogue/api/rdf/Resources/id=PELAGIE> a ldp:DirectContainer,
    dcat:Dataset;
  ldp:membershipResource <http://localhost:8080/catalogue/api/rdf/Endpoint/id=main_fdp>;
  ldp:hasMemberRelation fdp-o:metadataCatalog;
  dcterms:identifier "https://placeholder-pid/pelagie.org";
  dcterms:title "Perturbateurs Endocriniens: Ã‰tude Longitudinale sur les Anomalies de la Grossesse, lâ€™Infertilit";
  rdfs:label "Perturbateurs Endocriniens: Ã‰tude Longitudinale sur les Anomalies de la Grossesse, lâ€™Infertilit";
  dcterms:alternative "PELAGIE";
  dcat:landingPage <http://www.pelagie-inserm.fr/>;
  foaf:homepage <http://www.pelagie-inserm.fr/>;
  dcterms:description "The PELAGIE mother-child cohort was set up with the aim to study the effect of prenatal exposure to environmental and occupational chemicals on reproduction and child development. The PELAGIE cohort enrolled 3421 pregnant women from Brittany, France between 2002 and 2006. Offsprings were followed at delivery (n=3439) and at 2 (n=1506), 6 (n=1406) and 12 (n=1211) years old. Almost all women provided a urine samples at inclusion. Cord blood samples, maternal hair samples and pieces of placenta were collected for 55%, 60%, and 57% of the participants, respectively. A subgroup of 287 and 559 children performed a more in-depth follow-up including a clinical examination and biological sample collection at age 6 and 12 years old, respectively.";
  dcat:keyword "Pregnancy; Child; environment; growth; development; neurodevelopment; pesticides; solvant; occupation";
  dcat:startDate "2002"^^xsd:int;
  dcat:endDate "2006"^^xsd:int;
  healthdcatap:numberOfUniqueIndividuals "3421"^^xsd:nonNegativeInteger;
  dcterms:spatial <http://publications.europa.eu/resource/authority/country/FRA>, <http://localhost:8080/CatalogueOntologies/api/rdf/Regions/name=Bretagne>;
  dcterms:publisher <http://localhost:8080/catalogue/api/rdf/Agents/id=INSERM&resource=PELAGIE>;
  dcterms:creator <http://localhost:8080/catalogue/api/rdf/Agents/id=INSERM&resource=PELAGIE>;
  dcat:contactPoint <http://localhost:8080/catalogue/api/rdf/Contacts/firstName=Rob&lastName=Boss&resource=PELAGIE>;
  dcterms:accessRights <http://publications.europa.eu/resource/authority/access-right/NON_PUBLIC>;
