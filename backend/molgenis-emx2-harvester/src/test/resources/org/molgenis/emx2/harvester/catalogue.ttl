<http://localhost:8080/catalogue/api/rdf/Resources/id=DFBC> a ldp:DirectContainer,
    dcat:Dataset;
  ldp:membershipResource <http://localhost:8080/catalogue/api/rdf/Endpoint/id=main_fdp>;
