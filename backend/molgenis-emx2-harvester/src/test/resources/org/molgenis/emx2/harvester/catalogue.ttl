  dcat:landingPage <https://www.fhi.no/en/studies/moba/>;
  foaf:homepage <https://www.fhi.no/en/studies/moba/>;
  dcterms:description "MoBa is a Norwegian population-based longitudinal cohort study of around 114,500 children, 95,000 mothers and 75,000 fathers. Recruitment of pregnant women attending routine ultrasound examination took place between 1999 and 2009, and MoBa has since grown to become one of the largest population studies in the world. Baseline questionnaires were completed at around 15 weeksâ€™ gestation, and two further prenatal questionnaires were administered at around 17-22 and 30 weeksâ€™ gestation. In addition, fathers completed a questionnaire at around 15â€™ weeks gestation. Follow-up questionnaires after birth were completed at 6 months, 18 months, 36 months, 5 years, 7 years, and 8 years of age, and data are currently being collected through questionnaires for children aged 13 and 14 years. The purpose of MoBa is to improve our knowledge of diseases and health, by estimating exposure-outcome associations among children and their parents from preconception and pr";
  dcat:keyword "test2", "test1";
  dcat:startDate "1999"^^xsd:int;
  dcat:endDate "2008"^^xsd:int;
  healthdcatap:numberOfUniqueIndividuals "114000"^^xsd:nonNegativeInteger;
  dcterms:spatial <http://publications.europa.eu/resource/authority/country/NOR>;
  dcterms:publisher <http://localhost:8080/catalogue/api/rdf/Agents/id=NIPH&resource=MoBa>;
  dcterms:creator <http://localhost:8080/catalogue/api/rdf/Agents/id=NIPH&resource=MoBa>;
  dcat:contactPoint <http://localhost:8080/catalogue/api/rdf/Contacts/firstName=Rob&lastName=Boss&resource=MoBa>;
  dcterms:accessRights <http://publications.europa.eu/resource/authority/access-right/NON_PUBLIC>;
  dcterms:accrualPeriodicity <http://publications.europa.eu/resource/authority/frequency/CONT>;
