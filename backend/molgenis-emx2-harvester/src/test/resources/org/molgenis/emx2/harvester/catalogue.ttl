<http://localhost:8080/catalogue/api/rdf/Resources/id=ATHLETE> a ldp:DirectContainer,
    dcat:Catalog;
  ldp:membershipResource <http://localhost:8080/catalogue/api/rdf/Endpoint/id=main_fdp>;
  ldp:hasMemberRelation fdp-o:metadataCatalog;
  dcterms:identifier "https://placeholder-pid/athlete.org";
  dcterms:title "Advancing Tools for Human Early Lifecourse Exposome Research and Translation";
  dcterms:alternative "ATHLETE";
  dcat:landingPage <https://athleteproject.eu/>;
  foaf:homepage <https://athleteproject.eu/>;
  dcterms:description "Children are particularly vulnerable to environmental hazards. The ATHLETE project will measure a wide range of environmental exposures (urban, chemical, lifestyle and social risk factors) during pregnancy, childhood, and adolescence. The project will then link this â€œearly-life exposomeâ€ to childrenâ€™s biological responses and cardiometabolic, respiratory, and mental health. The results will help us to better understand and prevent health damage from environmental agents from the earliest parts of the life course onward.";
  dcat:keyword "test2", "test1";
  dcterms:conformsTo <https://specs.fairdatapoint.org/fdp-specs-v1.2.html>;
  dcat:dataset <http://localhost:8080/catalogue/api/rdf/Resources/id=INMA>, <http://localhost:8080/catalogue/api/rdf/Resources/id=Sepages>,
    <http://localhost:8080/catalogue/api/rdf/Resources/id=PELAGIE>, <http://localhost:8080/catalogue/api/rdf/Resources/id=BIB>,
    <http://localhost:8080/catalogue/api/rdf/Resources/id=GenR>, <http://localhost:8080/catalogue/api/rdf/Resources/id=MoBa>,
    <http://localhost:8080/catalogue/api/rdf/Resources/id=EDEN>, <http://localhost:8080/catalogue/api/rdf/Resources/id=ELSPAC>,
    <http://localhost:8080/catalogue/api/rdf/Resources/id=G21>, <http://localhost:8080/catalogue/api/rdf/Resources/id=DNBC>,
    <http://localhost:8080/catalogue/api/rdf/Resources/id=KANC>, <http://localhost:8080/catalogue/api/rdf/Resources/id=GenR%20Next>;
  dcterms:publisher <http://localhost:8080/catalogue/api/rdf/Agents/id=place-holder-organisation&resource=ATHLETE>;
  dcterms:creator <http://localhost:8080/catalogue/api/rdf/Agents/id=place-holder-organisation&resource=ATHLETE>;
  dcat:contactPoint <http://localhost:8080/catalogue/api/rdf/Contacts/firstName=Rob&lastName=Boss&resource=ATHLETE>;
