{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://molgenis.org/molgenis-model.schema.json",
  "title" : "MOLGENIS model bundle",
  "$defs" : {
    "columnEntry" : {
      "anyOf" : [
        {
          "type" : "string"
        },
        {
          "$ref" : "#/$defs/columnDefinition"
        },
        {
          "$ref" : "#/$defs/heading"
        }
      ]
    },
    "columnDefinition" : {
      "type" : "object",
      "required" : [
        "name"
      ],
      "properties" : {
        "name" : {
          "type" : "string"
        },
        "type" : {
          "anyOf" : [
            {
              "enum" : [
                "auto_id",
                "bool",
                "bool_array",
                "checkbox",
                "date",
                "date_array",
                "datetime",
                "datetime_array",
                "decimal",
                "decimal_array",
                "email",
                "email_array",
                "enum",
                "enum_array",
                "file",
                "hyperlink",
                "hyperlink_array",
                "int",
                "int_array",
                "json",
                "long",
                "long_array",
                "module",
                "module_array",
                "multiselect",
                "non_negative_int",
                "non_negative_int_array",
                "ontology",
                "ontology_array",
                "period",
                "period_array",
                "radio",
                "ref",
                "ref_array",
                "refback",
                "select",
                "string",
                "string_array",
                "text",
                "text_array",
                "uuid",
                "uuid_array"
              ]
            },
            {
              "type" : "string",
              "pattern" : "^(?:[aA][uU][tT][oO][__][iI][dD]|[bB][oO][oO][lL]|[bB][oO][oO][lL][__][aA][rR][rR][aA][yY]|[cC][hH][eE][cC][kK][bB][oO][xX]|[dD][aA][tT][eE]|[dD][aA][tT][eE][__][aA][rR][rR][aA][yY]|[dD][aA][tT][eE][tT][iI][mM][eE]|[dD][aA][tT][eE][tT][iI][mM][eE][__][aA][rR][rR][aA][yY]|[dD][eE][cC][iI][mM][aA][lL]|[dD][eE][cC][iI][mM][aA][lL][__][aA][rR][rR][aA][yY]|[eE][mM][aA][iI][lL]|[eE][mM][aA][iI][lL][__][aA][rR][rR][aA][yY]|[eE][nN][uU][mM]|[eE][nN][uU][mM][__][aA][rR][rR][aA][yY]|[fF][iI][lL][eE]|[hH][yY][pP][eE][rR][lL][iI][nN][kK]|[hH][yY][pP][eE][rR][lL][iI][nN][kK][__][aA][rR][rR][aA][yY]|[iI][nN][tT]|[iI][nN][tT][__][aA][rR][rR][aA][yY]|[jJ][sS][oO][nN]|[lL][oO][nN][gG]|[lL][oO][nN][gG][__][aA][rR][rR][aA][yY]|[mM][oO][dD][uU][lL][eE]|[mM][oO][dD][uU][lL][eE][__][aA][rR][rR][aA][yY]|[mM][uU][lL][tT][iI][sS][eE][lL][eE][cC][tT]|[nN][oO][nN][__][nN][eE][gG][aA][tT][iI][vV][eE][__][iI][nN][tT]|[nN][oO][nN][__][nN][eE][gG][aA][tT][iI][vV][eE][__][iI][nN][tT][__][aA][rR][rR][aA][yY]|[oO][nN][tT][oO][lL][oO][gG][yY]|[oO][nN][tT][oO][lL][oO][gG][yY][__][aA][rR][rR][aA][yY]|[pP][eE][rR][iI][oO][dD]|[pP][eE][rR][iI][oO][dD][__][aA][rR][rR][aA][yY]|[rR][aA][dD][iI][oO]|[rR][eE][fF]|[rR][eE][fF][__][aA][rR][rR][aA][yY]|[rR][eE][fF][bB][aA][cC][kK]|[sS][eE][lL][eE][cC][tT]|[sS][tT][rR][iI][nN][gG]|[sS][tT][rR][iI][nN][gG][__][aA][rR][rR][aA][yY]|[tT][eE][xX][tT]|[tT][eE][xX][tT][__][aA][rR][rR][aA][yY]|[uU][uU][iI][dD]|[uU][uU][iI][dD][__][aA][rR][rR][aA][yY])$"
            }
          ]
        },
        "key" : {
          "type" : "integer"
        },
        "required" : {
          "type" : [
            "boolean",
            "string"
          ]
        },
        "readonly" : {
          "type" : "boolean"
        },
        "defaultValue" : {
          "type" : "string"
        },
        "validation" : {
          "type" : "string"
        },
        "visible" : {
          "type" : "string"
        },
        "computed" : {
          "type" : "string"
        },
        "semantics" : {
          "type" : "array",
          "items" : {
            "type" : "string"
          }
        },
        "profiles" : {
          "type" : "array",
          "items" : {
            "type" : "string"
          }
        },
        "previousNames" : {
          "type" : "array",
          "items" : {
            "type" : "string"
          }
        },
        "description" : {
          "type" : "string"
        },
        "label" : {
          "type" : "string"
        },
        "formLabel" : {
          "type" : "string"
        },
        "subclass" : {
          "type" : "string"
        },
        "module" : {
          "type" : "string"
        },
        "drop" : {
          "type" : "boolean"
        }
      },
      "patternProperties" : {
        "^label@[A-Za-z][A-Za-z0-9-]*$" : {
          "type" : "string"
        },
        "^description@[A-Za-z][A-Za-z0-9-]*$" : {
          "type" : "string"
        }
      },
      "allOf" : [
        {
          "if" : {
            "required" : [
              "type"
            ],
            "properties" : {
              "type" : {
                "enum" : [
                  "checkbox",
                  "multiselect",
                  "ontology",
                  "ontology_array",
                  "radio",
                  "ref",
                  "ref_array",
                  "refback",
                  "select"
                ]
              }
            }
          },
          "then" : {
            "properties" : {
              "refBack" : {
                "type" : "string"
              },
              "refLabel" : {
                "type" : "string"
              },
              "refLink" : {
                "type" : "string"
              },
              "refTable" : {
                "type" : "string"
              }
            }
          }
        },
        {
          "if" : {
            "required" : [
              "type"
            ],
            "properties" : {
              "type" : {
                "enum" : [
                  "enum",
                  "enum_array",
                  "module",
                  "module_array"
                ]
              }
            }
          },
          "then" : {
            "properties" : {
              "values" : {
                "type" : "array",
                "items" : {
                  "type" : "string"
                }
              }
            }
          }
        }
      ],
      "unevaluatedProperties" : false
    },
    "heading" : {
      "type" : "object",
      "anyOf" : [
        {
          "required" : [
            "section"
          ]
        },
        {
          "required" : [
            "heading"
          ]
        }
      ],
      "properties" : {
        "section" : {
          "type" : "string"
        },
        "heading" : {
          "type" : "string"
        },
        "visible" : {
          "type" : "string"
        },
        "label" : {
          "type" : "string"
        },
        "description" : {
          "type" : "string"
        },
        "semantics" : {
          "type" : "array",
          "items" : {
            "type" : "string"
          }
        },
        "profiles" : {
          "type" : "array",
          "items" : {
            "type" : "string"
          }
        },
        "subclass" : {
          "type" : "string"
        },
        "module" : {
          "type" : "string"
        }
      },
      "patternProperties" : {
        "^label@[A-Za-z][A-Za-z0-9-]*$" : {
          "type" : "string"
        },
        "^description@[A-Za-z][A-Za-z0-9-]*$" : {
          "type" : "string"
        }
      },
      "unevaluatedProperties" : false
    },
    "subtable" : {
      "type" : "object",
      "required" : [
        "name"
      ],
      "properties" : {
        "name" : {
          "type" : "string"
        },
        "extends" : {
          "anyOf" : [
            {
              "type" : "string"
            },
            {
              "type" : "array",
              "items" : {
                "type" : "string"
              }
            }
          ]
        },
        "label" : {
          "type" : "string"
        },
        "description" : {
          "type" : "string"
        },
        "tableType" : {
          "anyOf" : [
            {
              "enum" : [
                "data",
                "module",
                "ontology"
              ]
            },
            {
              "type" : "string",
              "pattern" : "^(?:[dD][aA][tT][aA]|[mM][oO][dD][uU][lL][eE]|[oO][nN][tT][oO][lL][oO][gG][yY])$"
            }
          ]
        },
        "semantics" : {
          "type" : "array",
          "items" : {
            "type" : "string"
          }
        },
        "profiles" : {
          "type" : "array",
          "items" : {
            "type" : "string"
          }
        },
        "drop" : {
          "type" : "boolean"
        }
      },
      "patternProperties" : {
        "^label@[A-Za-z][A-Za-z0-9-]*$" : {
          "type" : "string"
        },
        "^description@[A-Za-z][A-Za-z0-9-]*$" : {
          "type" : "string"
        }
      },
      "unevaluatedProperties" : false
    },
    "tableFile" : {
      "type" : "object",
      "required" : [
        "name"
      ],
      "properties" : {
        "name" : {
          "type" : "string"
        },
        "label" : {
          "type" : "string"
        },
        "description" : {
          "type" : "string"
        },
        "settings" : {
          "type" : "object"
        },
        "columns" : {
          "type" : "array",
          "items" : {
            "$ref" : "#/$defs/columnEntry"
          }
        },
        "extends" : {
          "anyOf" : [
            {
              "type" : "string"
            },
            {
              "type" : "array",
              "items" : {
                "type" : "string"
              }
            }
          ]
        },
        "tableType" : {
          "anyOf" : [
            {
              "enum" : [
                "data",
                "module",
                "ontology"
              ]
            },
            {
              "type" : "string",
              "pattern" : "^(?:[dD][aA][tT][aA]|[mM][oO][dD][uU][lL][eE]|[oO][nN][tT][oO][lL][oO][gG][yY])$"
            }
          ]
        },
        "subclasses" : {
          "type" : "array",
          "items" : {
            "$ref" : "#/$defs/subtable"
          }
        },
        "modules" : {
          "type" : "array",
          "items" : {
            "$ref" : "#/$defs/subtable"
          }
        },
        "semantics" : {
          "type" : "array",
          "items" : {
            "type" : "string"
          }
        },
        "profiles" : {
          "type" : "array",
          "items" : {
            "type" : "string"
          }
        },
        "imports" : {
          "type" : "array",
          "items" : {
            "type" : "string"
          }
        },
        "drop" : {
          "type" : "boolean"
        }
      },
      "patternProperties" : {
        "^label@[A-Za-z][A-Za-z0-9-]*$" : {
          "type" : "string"
        },
        "^description@[A-Za-z][A-Za-z0-9-]*$" : {
          "type" : "string"
        }
      },
      "unevaluatedProperties" : false
    },
    "sharedFile" : {
      "type" : "object",
      "required" : [
        "columns"
      ],
      "properties" : {
        "columns" : {
          "type" : "array",
          "items" : {
            "$ref" : "#/$defs/columnEntry"
          }
        }
      },
      "unevaluatedProperties" : false
    },
    "tableEntry" : {
      "anyOf" : [
        {
          "type" : "string"
        },
        {
          "$ref" : "#/$defs/tableFile"
        }
      ]
    },
    "companionEntry" : {
      "type" : "object",
      "properties" : {
        "tables" : {
          "type" : "array",
          "items" : {
            "$ref" : "#/$defs/tableEntry"
          }
        },
        "data" : {
          "anyOf" : [
            {
              "type" : "string"
            },
            {
              "type" : "array",
              "items" : {
                "type" : "string"
              }
            }
          ]
        },
        "demo" : {
          "anyOf" : [
            {
              "type" : "string"
            },
            {
              "type" : "array",
              "items" : {
                "type" : "string"
              }
            }
          ]
        },
        "settings" : {
          "type" : "object"
        },
        "version" : {
          "type" : "string",
          "pattern" : "^\\d+\\.\\d+\\.\\d+$"
        },
        "permissions" : {
          "type" : "object"
        },
        "bundle" : {
          "type" : "string"
        }
      },
      "unevaluatedProperties" : false
    },
    "bundle" : {
      "type" : "object",
      "properties" : {
        "formatVersion" : {
          "type" : "integer"
        },
        "version" : {
          "type" : "string",
          "pattern" : "^\\d+\\.\\d+\\.\\d+$"
        },
        "tables" : {
          "type" : "array",
          "items" : {
            "$ref" : "#/$defs/tableEntry"
          }
        },
        "settings" : {
          "type" : "object"
        },
        "imports" : {
          "type" : "array",
          "items" : {
            "type" : "string"
          }
        },
        "namespaces" : {
          "type" : "object"
        },
        "additionalSchemas" : {
          "type" : "object",
          "additionalProperties" : {
            "$ref" : "#/$defs/companionEntry"
          }
        },
        "permissions" : {
          "type" : "object"
        },
        "data" : {
          "anyOf" : [
            {
              "type" : "string"
            },
            {
              "type" : "array",
              "items" : {
                "type" : "string"
              }
            }
          ]
        },
        "demo" : {
          "anyOf" : [
            {
              "type" : "string"
            },
            {
              "type" : "array",
              "items" : {
                "type" : "string"
              }
            }
          ]
        }
      },
      "unevaluatedProperties" : false
    }
  },
  "anyOf" : [
    {
      "$ref" : "#/$defs/bundle"
    },
    {
      "$ref" : "#/$defs/tableFile"
    },
    {
      "$ref" : "#/$defs/sharedFile"
    }
  ]
}
