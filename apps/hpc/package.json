{
  "name": "hpc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "cross-env NUXT_APP_BASE_URL='/apps/hpc/' nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "if-env CI=true && nuxt prepare || echo 'CI is not set'",
    "format": "prettier . --write --config ../.prettierrc.js --ignore-path ../.prettierignore",
    "checkFormat": "prettier . --check --config ../.prettierrc.js --ignore-path ../.prettierignore"
  },
  "dependencies": {
    "floating-vue": "5.2.2",
    "ofetch": "1.4.1",
    "vue": "3.5.22"
  },
  "devDependencies": {
    "@nuxtjs/tailwindcss": "6.14.0",
    "cross-env": "7.0.3",
    "if-env": "1.0.4",
    "nuxt": "4.4.2",
    "prettier": "2.8.8",
    "tailwind-components": "*",
    "tailwindcss": "3.4.17",
    "typescript": "5.6.2"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions"
  ]
}
