{
  "private": true,
  "name": "emx2-frontend",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint --filter=tailwind-components --filter=catalogue --filter=ui",
    "format": "turbo run format",
    "checkFormat": "turbo run checkFormat",
    "test-ci": "turbo run test-ci test-dev-env test-build-cache",
    "test-dev-env": "node --test dev-env.test.js",
    "test-build-cache": "node --test build-cache.test.js",
    "e2e": "turbo run e2e"
  },
  "dependencies": {
    "turbo": "2.9.14"
  }
}
